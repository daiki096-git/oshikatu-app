<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>

<div id="analyze">
  <label for="month">年・月を選択してください</label>
  <div>
    <select id="year">
      <% for (let y = Math.min(2025, currentYear); y <= currentYear; y++) { %>
      <option value="<%= y %>" <%= currentYear === y ? 'selected' : '' %>><%= y %>年</option>
      <% } %>
    </select>
  </div>
  <div>
    <select id="month">
      <option value="1" <%= currentMonth === 1 ? 'selected' : '' %>>1月</option>
      <option value="2" <%= currentMonth === 2 ? 'selected' : '' %>>2月</option>
      <option value="3" <%= currentMonth === 3 ? 'selected' : '' %>>3月</option>
      <option value="4" <%= currentMonth === 4 ? 'selected' : '' %>>4月</option>
      <option value="5" <%= currentMonth === 5 ? 'selected' : '' %>>5月</option>
      <option value="6" <%= currentMonth === 6 ? 'selected' : '' %>>6月</option>
      <option value="7" <%= currentMonth === 7 ? 'selected' : '' %>>7月</option>
      <option value="8" <%= currentMonth === 8 ? 'selected' : '' %>>8月</option>
      <option value="9" <%= currentMonth === 9 ? 'selected' : '' %>>9月</option>
      <option value="10" <%= currentMonth === 10 ? 'selected' : '' %>>10月</option>
      <option value="11" <%= currentMonth === 11 ? 'selected' : '' %>>11月</option>
      <option value="12" <%= currentMonth === 12 ? 'selected' : '' %>>12月</option>
    </select>
  </div>
</div>

<div id="chart-message"></div>

<div id="chart-results" hidden>
  <div id="oshikatu-percent"></div>
  <div class="chart-container">
    <canvas id="myPieChart"></canvas>
  </div>
  <div id="oshikatu-cost"></div>
  <div class="chart-container">
    <canvas id="myCostPieChart"></canvas>
  </div>
</div>

<script>
  const CATEGORY_COLORS = ["#E3A08D", "#E4C67F", "#A9C2A0", "#A9C0D6", "#C3AFD4"];
  const year = document.getElementById('year')
  const month = document.getElementById('month')
  let myChart = null;
  let myCostChart = null;

  const loadChart = async (selectedYear, selectedMonth) => {
    const message = document.getElementById('chart-message');
    try {
      const response = await fetch(`/api/chart?year=${selectedYear}&month=${selectedMonth}`)
      const data = await response.json();

      if (response.ok) {
        message.textContent = ``;
        document.getElementById('chart-results').hidden = false;
        const ctx = document.getElementById('myPieChart').getContext('2d');
        const ctx_cost = document.getElementById('myCostPieChart').getContext('2d');
        if (myChart) {
          myChart.destroy();
          myChart = null;
        }
        if (myCostChart) {
          myCostChart.destroy();
          myCostChart = null;
        }
        const count = [data?.data[4]?.count || 0, data?.data[3]?.count || 0, data?.data[2]?.count || 0, data?.data[1]?.count || 0, data?.data[0]?.count || 0]
        const cost = [data?.data[4]?.cost || 0, data?.data[3]?.cost || 0, data?.data[2]?.cost || 0, data?.data[1]?.cost || 0, data?.data[0]?.cost || 0]
        myChart = new Chart(ctx, {
          type: 'doughnut',
          data: {
            labels: ['イベント', 'グッズ', '交流', '記念日', '個人活動'],
            datasets: [{
              label: '割合(%)',
              data: count,
              backgroundColor: CATEGORY_COLORS,
              borderColor: "#FFFFFF",
              borderWidth: 2,
              hoverOffset: 4
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '58%',
            plugins: { legend: { position: 'bottom', labels: { font: { family: "'Zen Maru Gothic', sans-serif" }, color: '#5A5248', padding: 14, boxWidth: 12, usePointStyle: true } } }
          }
        });
        myCostChart = new Chart(ctx_cost, {
          type: 'doughnut',
          data: {
            labels: ['イベント', 'グッズ', '交流', '記念日', '個人活動'],
            datasets: [{
              label: '費用(円)',
              data: cost,
              backgroundColor: CATEGORY_COLORS,
              borderColor: "#FFFFFF",
              borderWidth: 2,
              hoverOffset: 4
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '58%',
            plugins: { legend: { position: 'bottom', labels: { font: { family: "'Zen Maru Gothic', sans-serif" }, color: '#5A5248', padding: 14, boxWidth: 12, usePointStyle: true } } }
          }
        });

        const oshikatu = document.getElementById("oshikatu-percent");
        const oshikatu_cost = document.getElementById("oshikatu-cost");
        const daysInMonth = new Date(selectedYear, selectedMonth, 0).getDate();
        let oshikatu_percent = Math.ceil((data.total / daysInMonth) * 100)
        oshikatu.textContent = `${selectedYear}年${selectedMonth}月の活動回数：${data.total}回（活動率${oshikatu_percent}%）`
        oshikatu_cost.textContent = `${selectedYear}年${selectedMonth}月の活動費用：${data.cost_total}円`

      } else {
        if (myChart) {
          myChart.destroy();
          myChart = null;
        }
        if (myCostChart) {
          myCostChart.destroy();
          myCostChart = null;
        }
        const oshikatu = document.getElementById("oshikatu-percent");
        const oshikatu_cost = document.getElementById("oshikatu-cost");
        oshikatu.textContent = ``
        oshikatu_cost.textContent = ``
        document.getElementById('chart-results').hidden = true;
        message.textContent = `データがありません`;
        return
      }

    } catch (error) {
      alert("サーバーエラーが発生しました")
      throw error;

    }
  }

  // 年・月どちらを変更しても再取得する
  const handleChange = () => {
    const selectedYear = year.value;
    const selectedMonth = month.value;
    if (!selectedYear) return alert("年を選択してください")
    if (!selectedMonth) return alert("月を選択してください")
    loadChart(selectedYear, selectedMonth);
  }
  year.addEventListener('change', handleChange)
  month.addEventListener('change', handleChange)

  // 初期表示：サーバーで選択済みの今年・今月で自動取得する
  window.addEventListener('DOMContentLoaded', () => {
    const selectedYear = year.value;
    const selectedMonth = month.value;
    if (selectedYear && selectedMonth) loadChart(selectedYear, selectedMonth);
  })
</script>
