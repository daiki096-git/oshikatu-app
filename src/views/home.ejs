
    <section class="tab-content active" id="home">
      <div class="card" id="activityTime"></div>
      <div class="card" id="total_cost"></div>
      <div class="card" id="next_event"></div>
    </section>

    

  <script>
      document.addEventListener("DOMContentLoaded", () => {
      const activityTime = document.getElementById("activityTime");
      const totalCost = document.getElementById("total_cost");
      const nextEvent = document.getElementById("next_event");
      const response = fetch('/api/home')
        .then(res => res.json())
        .then(data => {
          activityTime.textContent = `今月の推し活回数：${data.count}回`;
          totalCost.textContent = `今月の支出：${data.cost.toLocaleString()}円`;
          if (data.nextEventTitle && data.nextEventDate) {
            const nextEventDate = new Date(data.nextEventDate);
            const today = new Date();
            const diffTime = nextEventDate.getTime() - today.getTime();
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
            nextEvent.textContent = `次のイベント：${data.nextEventTitle}（あと${diffDays}日）`;
          } else {
            nextEvent.textContent = "次のイベント：データなし";
          }
        })
        .catch(err => {
          console.error('Error fetching activity time:', err);
          activityTime.textContent = '今月の推し活回数：データ取得エラー';
          totalCost.textContent = '今月の支出：データ取得エラー';
        });
    });
  </script>